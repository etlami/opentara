      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Export (CSV)" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Exportar (CSV)" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Exporter (CSV)" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Esporta (CSV)" } }
      }
    },
    "Farben = grobe Orientierung, keine medizinische Bewertung." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Colors = rough guidance, not a medical assessment." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Colores = orientación aproximada, no una evaluación médica." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Couleurs = indication approximative, pas une évaluation médicale." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Colori = orientamento approssimativo, non una valutazione medica." } }
      }
    },
    "Fertig" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Done" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Listo" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Terminé" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Fine" } }
      }
    },
    "Für ein eigenes Baby-/Tier-Profil kannst du oben rechts über das Profil-Symbol eine Person anlegen, z. B. Baby oder Hund." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "For a dedicated baby/pet profile, create a person via the profile icon at the top right, e.g. Baby or Dog." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Para un perfil de bebé/mascota, crea una persona con el icono de perfil arriba a la derecha, p. ej. Bebé o Perro." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Pour un profil bébé/animal dédié, créez une personne via l'icône de profil en haut à droite, p. ex. Bébé ou Chien." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Per un profilo dedicato a neonato/animale, crea una persona tramite l'icona del profilo in alto a destra, es. Neonato o Cane." } }
      }
    },
    "Für eine Prognose sind mehrere Messungen über mindestens einen Tag nötig." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A projection needs several measurements spanning at least one day." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Una previsión necesita varias mediciones a lo largo de al menos un día." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Une prévision nécessite plusieurs mesures sur au moins une journée." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Una previsione richiede più misurazioni nell'arco di almeno un giorno." } }
      }
    },
    "Für Fett/Wasser/Muskel bitte **barfuß** messen – dann kommt die Impedanz mit." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "For fat/water/muscle, measure **barefoot** – then impedance is included." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Para grasa/agua/músculo, mide **descalzo** – así se incluye la impedancia." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Pour la graisse/l'eau/le muscle, mesurez **pieds nus** – l'impédance est alors incluse." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Per grasso/acqua/muscolo, misura **a piedi nudi** – così è inclusa l'impedenza." } }
      }
    },
    "Geburtsdatum" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Date of birth" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Fecha de nacimiento" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Date de naissance" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Data di nascita" } }
