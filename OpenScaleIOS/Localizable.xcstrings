    },
    "Erinnerungen sind für OpenTara deaktiviert. Bitte in den iOS-Einstellungen unter Mitteilungen erlauben." : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Notifications are disabled for OpenTara. Please enable them in iOS Settings under Notifications." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Las notificaciones están desactivadas para OpenTara. Actívalas en Ajustes de iOS en Notificaciones." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les notifications sont désactivées pour OpenTara. Activez-les dans Réglages iOS sous Notifications." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Le notifiche sono disattivate per OpenTara. Attivale in Impostazioni iOS in Notifiche." } }
      }
